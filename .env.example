# Local development defaults
NODE_ENV=development
PORT=3000

# Database
# Set this in Render/Vercel dashboard for production
MONGODB_URI=

# Security (required in production)
# DTVS_SECRET must be exactly 64 hex characters
DTVS_SECRET=
# SESSION_SECRET should be at least 64 characters
SESSION_SECRET=

# Optional first-run admin bootstrap (used when DB has no users)
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Session cookie behavior
# strict | lax | none
# Use 'none' only when frontend and backend are on different domains
COOKIE_SAME_SITE=lax

# Notifications (optional)
MAIL_USER=
MAIL_PASS=

# Cloudinary (required in production if using Documents upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
